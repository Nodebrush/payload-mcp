{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "target": "ES2022",
    "paths": {
      "@payload-config/*": ["../../packages/payload-config/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
